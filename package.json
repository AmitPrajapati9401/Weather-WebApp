    },
    "flatted": "^3.4.2",
    "jsonpath": "^1.3.0",
    "lodash": "^4.18.1",
    "rollup": "^2.80.0",
    "svgo": "^2.8.1",
    "js-yaml": "^3.14.2 || ^4.1.1",
    "@tootallnate/once": "^2.0.1"
  }
