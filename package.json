{
  "name": "weather-react",
  "version": "2.10.0",
  "dependencies": {
    "@sentry/browser": "^9.47.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "axios": "^1.16.1",
    "axios-retry": "^4.5.0",
    "lodash-es": "^4.18.1",
    "logrocket": "^10.1.1",
    "logrocket-react": "^6.0.3",
    "moment-timezone": "^0.5.48",
    "npm-run-all": "^4.1.5",
    "nuka-carousel": "^4.8.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-ga": "^3.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.16.0",
    "react-scripts": "^5.0.1",
    "react-toggle": "^4.1.3"
  },
  "scripts": {
    "scss": "sass src/sass/styles.scss:src/styles/styles.css",
    "watch-scss": "sass --watch src/sass/styles.scss:src/styles/styles.css",
    "build-scss": "npm run scss",
    "watch:style": "postcss src/styles/styles.css -o src/styles/main.css -w",
    "build:style": "postcss src/styles/styles.css -o src/styles/main.css",
    "watch-css": "npm-run-all -p watch-scss watch:style",
    "build-css": "npm-run-all -s build-scss build:style",
    "start-react": "react-scripts start",
    "start": "npm-run-all -p watch-css start-react",
    "build-react": "react-scripts build",
    "build": "npm-run-all -s build-css build-react",
    "test": "react-scripts test --transformIgnorePatterns \"node_modules/(?!lodash-es)/\" --env=jsdom",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss-cli": "^11.0.1",
    "react-test-renderer": "^18.3.1",
    "sass": "^1.100.0",
    "tailwindcss": "^3.4.19"
  },
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "postcss": "^8.5.15",
    "nth-check": "^2.1.1",
    "serialize-javascript": "^7.0.5",
    "node-forge": "^1.4.0",
    "follow-redirects": "^1.16.0",
    "ws": "^8.21.0",
    "yaml": "^1.10.3 || ^2.8.3",
    "webpack": "^5.104.1",
    "minimatch": "^3.1.4 || ^5.1.8 || ^9.0.7",
    "brace-expansion": "^1.1.13 || ^2.0.3",
    "qs": "^6.15.2",
    "path-to-regexp": "^0.1.13",
    "fast-uri": "^3.1.2",
    "underscore": "^1.13.8",
    "uuid": "^11.1.1",
    "picomatch": "^2.3.2",
    "tinyglobby": {
